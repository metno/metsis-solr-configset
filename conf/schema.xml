<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE schema [
<!ENTITY extratypes SYSTEM "schema_extra_types.xml">
]>

<schema name="metsis-adc-4.x" version="1.7">
  <!-- Solr Specific fields -->
  <field name="_version_" type="plong" indexed="false" stored="false"/>
  <field name="_root_" type="string" indexed="true" stored="false" />

  <!-- The Highlighter Component requires the id field to be "stored" even if docValues are set. -->
  <field name="id" type="string" indexed="true" stored="true" required="true" multiValued="false"/>

  <!-- Here, default is used to create a "timestamp" field indicating
       when each document was indexed.-->
  <field name="timestamp" type="pdate" indexed="true" stored="false" default="NOW" multiValued="false" docValues="true"/>

  <uniqueKey>id</uniqueKey>

  <!-- Spatial fields used by METSIS search,-->

  <!-- Store the boundingbox created from the mmd geographical_extent elements -->
  <field name="bbox" type="bbox" indexed="true" stored="true" multiValued="false"/>

  <!-- Store more complex shapes and points extracted from ACDD geospatial_bounds.
    If ACDD geospatial_bounds was not provided or invalid. The A polygon of the bbox
    are stored here. -->

  <!-- DEPRECATED: This field with the JTS context are no longer used. geospatial_bounds3d are used instead. -->
  <field name="geospatial_bounds" type="location_rpt_jts" indexed="true" stored="true" multiValued="false" />
  <!-- This is the default geospatial_bounds field used in 4.x -->
  <field name="geospatial_bounds3d" type="geometry_rpt_geo3d" indexed="true" stored="true" multiValued="false" />
  <!-- Store the center of the geometry for proximity searches-->
  <field name="center" type="location" indexed="true" stored="true"/>

  <!-- Store WKT/GeoJSON Geometry as string for Map visualization (Openlayers/Leaflet)-->
  <field name="geometry_wkt" type="string" indexed="false" stored="true" multiValued="false" />
  <field name="geometry_geojson" type="string" indexed="false" stored="true" multiValued="false" />

  <!-- NEW MMD SPECIFICATION version 4.x -->

  <!-- mmd/metadata_identifier -->
  <field name="metadata_identifier" type="string" indexed="true" stored="true" required="false" multiValued="false"/>

  <!-- mmd/alternate_identifier -->
  <field name="alternate_identifier" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="alternate_identifier_type" type="string" indexed="true" stored="true" required="false" multiValued="true" />

  <!-- mmd/last_metadata_update
        last_metadata_update_json is the full mmd/last_metadata_update extracted as a json structure.
        last_metadata_created_date are the created date. i.e the first entry
        last_metadata_updated_date are the updated date. i.e the last entry (or first if only one entry).
  -->
  <field name="last_metadata_update_json" type="string" indexed="false" stored="true" required="false" multiValued="false" docValues="false"/>
  <field name="last_metadata_created_date" type="pdate" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="last_metadata_updated_date" type="pdate" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- mmd/metadata_status -->
  <field name="metadata_status" type="metadata_status_enum" indexed="true" stored="true" docValues="true" required="false" multiValued="false" />

  <!-- mmd/metadata_source (Internal/External)-->
  <field name="metadata_source" type="string" indexed="true" stored="false" required="false" multiValued="false" docValues="true" useDocValuesAsStored="true"/>

  <!-- mmd/collection -->
  <field name="collection" type="string" indexed="true" stored="false" required="false" multiValued="true" docValues="true" useDocValuesAsStored="true"/>

  <!-- mmd/title -->
  <field name="title" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="title_hl" type="text_gen_sort" indexed="false" stored="true" required="false" multiValued="false" />
  <field name="title_en" type="text_en" indexed="true" stored="false" required="false" multiValued="false" />
  <field name="title_no" type="text_nb" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- mmd/abstract -->
  <field name="abstract" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="abstract_hl" type="text_gen_sort" indexed="false" stored="true" required="false" multiValued="false" />
  <field name="abstract_en" type="text_en" indexed="true" stored="false" required="false" multiValued="false" />
  <field name="abstract_no" type="text_nb" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- mmd/temporal_extent -->
  <field name="temporal_extent_start_date" type="pdate" indexed="true" stored="true" docValues="true" sortMissingLast="true" required="false" multiValued="true" />
  <field name="temporal_extent_end_date" type="pdate" indexed="true" stored="true" docValues="true" sortMissingLast="false" required="false" multiValued="true" />

  <!-- mmd/geographic_extent/rectangle -->
  <field name="geographic_extent_rectangle_north" type="pdouble" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="geographic_extent_rectangle_south" type="pdouble" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="geographic_extent_rectangle_east" type="pdouble" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="geographic_extent_rectangle_west" type="pdouble" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="geographic_extent_rectangle_srsName" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <!-- mmd/geographic_extent/polygon added to geopatial_bounds if provided  -->

  <!-- mmd/dataset_production_status -->
  <field name="dataset_production_status" type="string" indexed="true" stored="true" required="false" multiValued="false" docValues="true"/>

  <!-- mmd/dataset_language -->
  <field name="dataset_language" type="string" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- mmd/operational_status -->
  <field name="operational_status" type="string" indexed="true" stored="true" required="false" multiValued="false" docValues="true"/>

  <!-- mmd/access_constraint -->
  <field name="access_constraint" type="string" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- mmd/use_constraint -->
  <field name="use_constraint_identifier" type="string" indexed="true" stored="true" required="false" multiValued="false" docValues="true"/>
  <field name="use_constraint_resource" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="use_constraint_license_text" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- mmd/personnel
        personnel_json are the full mmd/personnel extracted as a json structure.
        personnel_role for facet and filter
        personnel_name and personnel_organisation for display and highlighting.

        personnel_organisation_facet and personnel_name_facet are added by the solrindexer, and are used for faceting and filtering.
   -->
  <field name="personnel_json" type="string" indexed="false" stored="true" required="false" multiValued="false" docValues="false"/>
  <field name="personnel_role" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="personnel_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true"/>
  <field name="personnel_organisation" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true"/>

  <!-- mmd/data_center -->
  <field name="data_center_short_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="data_center_long_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="false" />
  <!-- Combined field using either short or long name depends on whats provided. Used for faceting and filtering -->
  <field name="data_center_name" type="string" indexed="true" stored="true" required="false" multiValued="false" docValues="true"/>
  <field name="data_center_url" type="string" indexed="false" stored="true" required="false" multiValued="false" />

  <!-- mmd/data_access
          data_access_json is the full mmd/data_access extracted as a json structure.
          data_access_type is the type of data access url, e.g. OPeNDAP, WMS, HTTP, etc. Used for faceting and filtering.
          data_access_wms_layers is the WMS layers if the data access type is WMS.
  -->
  <field name="data_access_json" type="string" indexed="false" stored="true" required="false" multiValued="false" docValues="false"/>
  <field name="data_access_type" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <field name="data_access_wms_layers" type="string" indexed="true" stored="true" required="false" multiValued="true" />

  <!-- mmd/related_dataset
        fields used for parent/child and auxiliary dataset relations.
           related_dataset and related_dataset_id are the metadata_identifier and solrid of the parent relation type.
           related_dataset_relation_type is the relation type e.g. parent, child, auxiliary, etc.
           related_dataset_auxiliary, related_dataset_auxiliary_id are the metadata_identifier and solrid of the auxiliary relation type.
  TODO: Consider naming related_dataset to related_parent_dataset and set multiValued false.
        Also consider removing/chaning field structure for other relation types.
  -->
  <field name="related_dataset" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="related_dataset_relation_type" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="related_dataset_id" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="related_dataset_auxiliary_id" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="related_dataset_auxiliary" type="string" indexed="true" stored="true" required="false" multiValued="true" />

  <!-- mmd/storage_information -->
  <field name="storage_information_file_name" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_file_location" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_file_format" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_file_size_unit" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_file_size" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_file_checksum_type" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_file_checksum" type="string" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_file_storage_expiry_date" type="pdate" indexed="true" stored="true" required="false" multiValued="false" />
  <field name="storage_information_responsible_unit" type="string" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- mmd/related_information
        related_information_json is the full mmd/related_information extracted as a json structure.
        related_information_type is the type of related information, e.g. observation facility, scientific publication, etc. Used for faceting and filtering.
        related_information_resource is the url or identifier of the related information.
        related_information_description is the description of the related information. Used for highlighting and display.
  -->
  <field name="related_information_json" type="string" indexed="false" stored="true" required="false" multiValued="false" docValues="false"/>
  <field name="related_information_type" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="related_information_resource" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="related_information_description" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />

  <!-- We store the related url landing page here so we do not need to extract it from the related information json -->
  <field name="related_url_landing_page" type="string" indexed="false" stored="true" required="false" multiValued="false" />

  <!-- related information obeservation facility. used for faceting and filtering. -->
  <field name="observation_facility" type="string" indexed="true" stored="false" required="false" multiValued="true" docValues="true" useDocValuesAsStored="true"/>

  <!-- mmd/iso_topic_category -->
  <field name="iso_topic_category" type="string" indexed="true" stored="false" required="false" multiValued="true" docValues="true" useDocValuesAsStored="true"/>

  <!-- mmd/keywords -->
  <field name="keywords_vocabulary" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <!-- The keywords_keyword field are used for highlighting -->
  <field name="keywords_keyword" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />

  <!-- GCMDSK keywords -->
  <field name="keywords_gcmd" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <!-- GCMDPLT keywords -->
  <field name="keywords_gcmdplt" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true" />
  <!-- GCMDINST keywords -->
  <field name="keywords_gcmdinst" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <!-- GCMDLOC keywords -->
  <field name="keywords_gcmdloc" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <!-- GCMDPROV keywords -->
  <field name="keywords_gcmdprov" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <!-- CFSTDN keywords -->
  <field name="keywords_cfstdn" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <!-- GEMET keywords -->
  <field name="keywords_gemet" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>
  <!-- NORTHEMES keywords -->
  <field name="keywords_northemes" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>

  <!-- ECV keywords https://vocab.nerc.ac.uk/collection/EXV/current/ -->
  <field name="keywords_exv" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>

  <!-- NONE keywords -->
  <field name="keywords_none" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>

  <!-- mmd/project
        project_short_name used for highlighting and display.
        project_long_name used for highlighting and display.
        project_name is the short or long name of the project. Used for highlighting and display.
        project_name_facet is the short or long name of the project. Used for faceting and filtering. Added by the solrindexer.
  -->
  <field name="project_short_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="project_long_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="project_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true"/>

  <!-- mmd/platform -->
  <field name="platform_json" type="string" indexed="false" stored="true" required="false" multiValued="false" docValues="false"/>
  <field name="platform_short_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_long_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />

  <field name="platform_resource" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_orbit_relative" type="pint" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_orbit_absolute" type="pint" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_orbit_direction" type="string" indexed="true" stored="true" required="false" multiValued="true" />

  <field name="platform_instrument_short_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_instrument_long_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_instrument_name" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_instrument_resource" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_instrument_mode" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_instrument_polarisation" type="string" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_instrument_product_type" type="string" indexed="true" stored="true" required="false" multiValued="true" />

  <field name="platform_ancillary_cloud_coverage" type="pdouble" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_ancillary_scene_coverage" type="pdouble" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="platform_ancillary_timeliness" type="string" indexed="true" stored="true" required="false" multiValued="true" />

  <!-- mmd/activity_type -->
  <field name="activity_type" type="string" indexed="true" stored="true" required="false" multiValued="true" docValues="true"/>

  <!-- mmd/dataset_citation -->
  <field name="dataset_citation_json" type="string" indexed="false" stored="true" required="false" multiValued="false" docValues="false"/>
  <field name="dataset_citation_publication_date" type="pdate" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="dataset_citation_title" type="text_en" indexed="true" stored="true" required="false" multiValued="true" />
  <field name="dataset_citation_doi" type="text_gen_sort" indexed="true" stored="true" required="false" multiValued="true" />

  <!-- Common fields for new and old MMD specification, specific for Drupal 8
   -->
  <field name="text_suggester" type="text_suggest" indexed="true" stored="false" required="false" multiValued="true" />
  <field name="match_exact" type="match_exact" indexed="true" stored="false" required="false" multiValued="true" />

  <!-- Field for storing analyzed and stemmed keywords -->
  <field name="text_keywords_stemmed" indexed="true" stored="false" multiValued="true" type="text_keyword_processed"/>
  <field name="cfstdn_keywords_stemmed" indexed="true" stored="false" multiValued="true" type="text_keyword_processed"/>
  <field name="gcmd_keywords_stemmed" indexed="true" stored="false" multiValued="true" type="text_keyword_processed"/>

  <!-- some internal mmd info -->
  <!-- the file_name.xml -->
  <field name="mmd_file_name" type="string" indexed="false" stored="true"/>

  <!-- the internal file path, if stored on some server -->
  <field name="mmd_file_path" type="string" indexed="false" stored="true"/>

  <!-- the path wich the file is stored on the repo (git) -->
  <field name="mmd_repo_path" type="string" indexed="false" stored="true"/>

  <!-- The mmd xml file -->
  <field name="mmd_xml_file" type="string" indexed="false" stored="true" docValues="false"/>
  <!-- Catch field for urls -->
  <field name="urls" type="url" indexed="true" stored="false" multiValued="true" />

  <!--DateRangeField for faceting between start and end dates -->
  <field name="temporal_extent_period_dr" type="date_ranges" indexed="true" stored="true" multiValued="true"/>

  <!-- Normalized data access_resources based on data access type alo normalised related information -->
  <field name="data_access_url_opendap" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="data_access_url_ogc_wms" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="data_access_url_ogc_wfs" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="data_access_url_ogc_wcs" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="data_access_url_http" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="data_access_url_odata" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="data_access_url_ftp" type="string" indexed="true" stored="true" multiValued="true"/>

  <!-- Thumbnail specific fields -->
  <field name="thumbnail" type="binary" indexed="false" stored="true" required="false" multiValued="false" />
  <field name="thumbnail_data" type="binary" indexed="false" stored="true" required="false" multiValued="false" />
  <field name="thumbnail_url" type="string" indexed="false" stored="true" required="false" multiValued="false" />
  <field name="feature_type" type="string" indexed="true" stored="true" required="false" multiValued="false" />

  <!-- Aggregated field for full text searches. Using Drupal Search api text_und -->
  <field name="full_text" type="text_en" indexed="true" stored="false" required="false" multiValued="true" />

  <!-- Boolean set to true for datasets which are parent datasets -->
  <field name="isParent" type="boolean" stored="true" />

  <!-- Boolean set to true for datasets which are auxiliary datasets -->
  <field name="isAuxiliary" type="boolean" stored="true" />

  <!-- Boolean set to true for datasets which are child datasets -->
  <field name="isChild" type="boolean" stored="true" />

  <!-- Spatial representation -->
  <field name="spatial_representation" type="string" indexed="true" stored="true" multiValued="false"/>

  <!-- Quality control  -->
  <field name="quality_control" type="string" indexed="true" stored="true" multiValued="false"/>


  <!-- dummy field -->
  <field name="text" type="string" indexed="false" stored="false" />

  <!-- Descriptions is a catch all field for any description fields in the MMD.
        Used for highlighting and display.
        Added by the solrindexer.
  -->
  <field name="descriptions" type="text_gen_sort" indexed="false" stored="true" multiValued="true"/>

  <!-- Resources field
      Catch all resource urls and identifeiers.
      Added by the solrindexer.
      Not stored or indexed, copied to urls, full_text and match_exact for search and faceting.
    -->
  <field name="resources" type="text_gen_sort" indexed="false" stored="true" multiValued="true"/>

  <!-- NBS Specific fields -->
  <field name="platform_sentinel" type="string" indexed="true" stored="true" multiValued="true"/>
  <field name="sentinel_tile" type="string" indexed="true" stored="true" />
  <field name="sentinel_mid" type="string" indexed="true" stored="true" />


  <!-- Index the temporal_extent dates in differnt data formats/granularity for faceting/filtering  -->
  <!-- CopyField definitions -->

  <!-- Catch all full text search-->
  <copyField source="metadata_identifier" dest="full_text" />
  <copyField source="alternate_identifier" dest="full_text" />
  <copyField source="activity_type" dest="full_text" />
  <copyField source="access_constraint" dest="full_text" />
  <copyField source="abstract_en" dest="full_text" />
  <copyField source="data_center_long_name" dest="full_text" />
  <copyField source="data_center_short_name" dest="full_text" />
  <copyField source="dataset_citation_doi" dest="full_text" />
  <copyField source="dataset_citation_title" dest="full_text" />
  <copyField source="iso_topic_category" dest="full_text" />
  <copyField source="keywords_keyword" dest="full_text" />
  <copyField source="personnel_name" dest="full_text" />
  <copyField source="personnel_organisation" dest="full_text" />
  <copyField source="personnel_role" dest="full_text" />
  <copyField source="platform_instrument_long_name" dest="full_text" />
  <copyField source="platform_instrument_short_name" dest="full_text" />
  <copyField source="platform_instrument_mode" dest="full_text" />
  <copyField source="platform_instrument_polarisation" dest="full_text" />
  <copyField source="platform_instrument_product_type" dest="full_text" />
  <copyField source="platform_ancillary_timeliness" dest="full_text" />
  <copyField source="platform_orbit_direction" dest="full_text" />
  <copyField source="platform_long_name" dest="full_text" />
  <copyField source="platform_short_name" dest="full_text" />
  <copyField source="project_long_name" dest="full_text" />
  <copyField source="project_short_name" dest="full_text" />
  <copyField source="storage_information_file_name" dest="full_text" />
  <copyField source="storage_information_file_format" dest="full_text" />
  <copyField source="related_dataset" dest="full_text"/>
  <copyField source="title_hl" dest="full_text" />
  <copyField source="descriptions" dest="full_text" />
  <copyField source="resources" dest="full_text" />
  <copyField source="use_constraint_license_text" dest="full_text" />
  <copyField source="use_constraint_identifier" dest="full_text" />
  <copyField source="operational_status" dest="full_text" />
  <copyField source="quality_control" dest="full_text" />
  <copyField source="spatial_representation" dest="full_text" />



  <!-- Copy fields for exact match search. No stemming/tokenizing-->
  <copyField source="metadata_identifier" dest="match_exact" />
  <copyField source="alternate_identifier" dest="match_exact" />
  <copyField source="activity_type" dest="match_exact" />
  <copyField source="data_center_long_name" dest="match_exact" />
  <copyField source="data_center_short_name" dest="match_exact" />
  <copyField source="dataset_citation_doi" dest="match_exact"/>
  <copyField source="dataset_citation_title" dest="match_exact" />
  <copyField source="iso_topic_category" dest="match_exact" />
  <copyField source="keywords_keyword" dest="match_exact" />
  <copyField source="metadata_identifier" dest="match_exact" />
  <copyField source="personnel_name" dest="match_exact" />
  <copyField source="personnel_organisation" dest="match_exact" />
  <copyField source="platform_instrument_long_name" dest="match_exact" />
  <copyField source="platform_instrument_short_name" dest="match_exact" />
  <copyField source="platform_instrument_mode" dest="match_exact" />
  <copyField source="platform_instrument_polarisation" dest="match_exact" />
  <copyField source="platform_instrument_product_type" dest="match_exact" />
  <copyField source="platform_ancillary_timeliness" dest="match_exact" />
  <copyField source="platform_orbit_direction" dest="match_exact" />
  <copyField source="platform_orbit_relative" dest="match_exact" />
  <copyField source="platform_orbit_absolute" dest="match_exact" />
  <copyField source="storage_information_file_name" dest="match_exact" />
  <copyField source="storage_information_file_format" dest="match_exact" />
  <copyField source="platform_long_name" dest="match_exact" />
  <copyField source="platform_short_name" dest="match_exact" />
  <copyField source="project_long_name" dest="match_exact" />
  <copyField source="project_short_name" dest="match_exact" />
  <copyField source="related_dataset" dest="match_exact" />
  <copyField source="title" dest="match_exact" />
  <copyField source="descriptions" dest="match_exact" />
  <copyField source="resources" dest="match_exact" />
  <copyField source="use_constraint_identifier" dest="match_exact" />
  <copyField source="operational_status" dest="match_exact" />
  <copyField source="quality_control" dest="match_exact" />
  <copyField source="spatial_representation" dest="match_exact" />
  <copyField source="keywords_cfstdn" dest="match_exact" />


  <!-- Copy fields for stemmed keyword searches -->
  <copyField source="keywords_gcmd" dest="text_keywords_stemmed" />
  <copyField source="keywords_gcmdplt" dest="text_keywords_stemmed" />
  <copyField source="keywords_gcmdinst" dest="text_keywords_stemmed" />
  <copyField source="keywords_gcmdloc" dest="text_keywords_stemmed" />
  <copyField source="keywords_gcmdprov" dest="text_keywords_stemmed" />
  <copyField source="keywords_cfstdn" dest="text_keywords_stemmed" />
  <copyField source="keywords_gemet" dest="text_keywords_stemmed" />
  <copyField source="keywords_northemes" dest="text_keywords_stemmed" />
  <copyField source="keywords_exv" dest="text_keywords_stemmed" />
  <copyField source="keywords_none" dest="text_keywords_stemmed" />

  <!-- Copy fields for suggester-->
  <copyField source="personnel_name" dest="text_suggester" />
  <copyField source="personnel_organisation" dest="text_suggester" />
  <copyField source="platform_instrument_long_name" dest="text_suggester" />
  <copyField source="platform_instrument_short_name" dest="text_suggester" />
  <copyField source="platform_long_name" dest="text_suggester" />
  <copyField source="platform_short_name" dest="text_suggester" />
  <copyField source="project_long_name" dest="text_suggester" />
  <copyField source="project_short_name" dest="text_suggester" />
  <copyField source="iso_topic_category" dest="text_suggester" />
  <copyField source="data_center_long_name" dest="text_suggester" />
  <copyField source="data_center_short_name" dest="text_suggester" />
  <copyField source="metadata_identifier" dest="text_suggester" />
  <copyField source="alternate_identifier" dest="text_suggester" />
  <copyField source="activity_type" dest="text_suggester" />
  <copyField source="keywords_keyword" dest="text_suggester" />
  <copyField source="title" dest="text_suggester" />
  <copyField source="descriptions" dest="text_suggester" />


  <!-- Urls copyfield-->
  <copyField source="resources" dest="urls" />
  <copyField source="*_url" dest="urls" />
  <copyField source="*_uri" dest="urls" />


  <!-- Define some dynamic field types. Not stored as they should only be used by copyField-->
  <dynamicField name="random_*" type="random"/>
  <dynamicField name="ignored_*" type="ignored"/>

  <!-- Dynamic field optimised for facetting. Fields of this type have to be added by the solr-indexer
       to  be compatible with atomic-updates -->
  <dynamicField name="*_facet" type="strings" indexed="true" stored="false" docValues="true"/>

  <!-- Enum type for metadata_status -->
  <fieldType name="metadata_status_enum" class="solr.EnumFieldType" enumsConfig="enumsConfig.xml" enumName="metadata_status"/>


  <!-- Custom METSIS fieldTypes -->
  <fieldType name="match_exact" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <tokenizer class="solr.KeywordTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.TrimFilterFactory"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.KeywordTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.TrimFilterFactory"/>
    </analyzer>

  </fieldType>

  <fieldType name="text_suggest" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <filter class="solr.PatternReplaceFilterFactory" pattern="^(https?://)?doi\.org/" replacement="" />
      <tokenizer class="solr.ClassicTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.ASCIIFoldingFilterFactory"/>
      <filter class="solr.EnglishPossessiveFilterFactory"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.ASCIIFoldingFilterFactory"/>
      <filter class="solr.EnglishPossessiveFilterFactory"/>
    </analyzer>
  </fieldType>


  <!-- Field types from Solr _default schema-->

  <!-- A general text field that has reasonable, generic
         cross-language defaults: it tokenizes with StandardTokenizer,
         removes stop words from case-insensitive "stopwords.txt"
         (empty by default), and down cases.  At query time only, it
         also applies synonyms.
    -->
  <fieldType name="text_general" class="solr.TextField" positionIncrementGap="100" multiValued="true">
    <analyzer type="index">
      <tokenizer name="standard"/>
      <filter name="stop" ignoreCase="true" words="stopwords.txt" />
      <!-- in this example, we will only use synonyms at query time
        <filter name="synonymGraph" synonyms="index_synonyms.txt" ignoreCase="true" expand="false"/>
        <filter name="flattenGraph"/>
        -->
      <filter name="lowercase"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer name="standard"/>
      <filter name="stop" ignoreCase="true" words="stopwords.txt" />
      <filter name="synonymGraph" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
      <filter name="lowercase"/>
    </analyzer>
  </fieldType>

  <!-- SortableTextField generaly functions exactly like TextField,
         except that it supports, and by default uses, docValues for sorting (or faceting)
         on the first 1024 characters of the original field values (which is configurable).

         This makes it a bit more useful then TextField in many situations, but the trade-off
         is that it takes up more space on disk; which is why it's not used in place of TextField
         for every fieldType in this _default schema.
    -->
  <fieldType name="text_gen_sort" class="solr.SortableTextField" positionIncrementGap="100" multiValued="true" storeOffsetsWithPositions="true" termVectors="true">
    <analyzer type="index">
      <tokenizer name="standard"/>
      <filter name="stop" ignoreCase="true" words="stopwords.txt" />
      <filter name="lowercase"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer name="standard"/>
      <filter name="stop" ignoreCase="true" words="stopwords.txt" />
      <filter name="synonymGraph" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
      <filter name="lowercase"/>
    </analyzer>
  </fieldType>

  <fieldType name="text_general_rev" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.StopFilterFactory" words="stopwords.txt" ignoreCase="true"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.ReversedWildcardFilterFactory" maxPosQuestion="2" maxFractionAsterisk="0.33" maxPosAsterisk="3" withOriginal="true"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.SynonymGraphFilterFactory" expand="true" ignoreCase="true" synonyms="synonyms.txt"/>
      <filter class="solr.StopFilterFactory" words="stopwords.txt" ignoreCase="true"/>
      <filter class="solr.LowerCaseFilterFactory"/>
    </analyzer>
  </fieldType>

  <!-- A text field with defaults appropriate for English, plus
         aggressive word-splitting and autophrase features enabled.
         This field is just like text_en, except it adds
         WordDelimiterGraphFilter to enable splitting and matching of
         words on case-change, alpha numeric boundaries, and
         non-alphanumeric chars.  This means certain compound word
         cases will work, for example query "wi fi" will match
         document "WiFi" or "wi-fi".
    -->
  <fieldType name="text_en_splitting" class="solr.TextField" positionIncrementGap="100" autoGeneratePhraseQueries="true">
    <analyzer type="index">
      <tokenizer name="whitespace"/>
      <!-- in this example, we will only use synonyms at query time
        <filter name="synonymGraph" synonyms="index_synonyms.txt" ignoreCase="true" expand="false"/>
        -->
      <!-- Case insensitive stop word removal.
        -->
      <filter name="stop" ignoreCase="true" words="stopwords_en.txt" />
      <filter name="wordDelimiterGraph" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1"/>
      <filter name="lowercase"/>
      <filter name="keywordMarker" protected="protwords.txt"/>
      <filter name="porterStem"/>
      <filter name="flattenGraph" />
    </analyzer>
    <analyzer type="query">
      <tokenizer name="whitespace"/>
      <filter name="synonymGraph" synonyms="synonyms.txt" ignoreCase="true" expand="true"/>
      <filter name="stop" ignoreCase="true" words="stopwords_en.txt" />
      <filter name="wordDelimiterGraph" generateWordParts="1" generateNumberParts="1" catenateWords="0" catenateNumbers="0" catenateAll="0" splitOnCaseChange="1"/>
      <filter name="lowercase"/>
      <filter name="keywordMarker" protected="protwords.txt"/>
      <filter name="porterStem"/>
    </analyzer>
  </fieldType>

  <!-- Less flexible matching, but less false matches.  Probably not ideal for product names,
         but may be good for SKUs.  Can insert dashes in the wrong place and still match. -->
  <fieldType name="text_en_splitting_tight" class="solr.TextField" positionIncrementGap="100" autoGeneratePhraseQueries="true">
    <analyzer type="index">
      <tokenizer name="whitespace"/>
      <filter name="synonymGraph" synonyms="synonyms.txt" ignoreCase="true" expand="false"/>
      <filter name="stop" ignoreCase="true" words="stopwords_en.txt"/>
      <filter name="wordDelimiterGraph" generateWordParts="0" generateNumberParts="0" catenateWords="1" catenateNumbers="1" catenateAll="0"/>
      <filter name="lowercase"/>
      <filter name="keywordMarker" protected="protwords.txt"/>
      <filter name="englishMinimalStem"/>
      <!-- this filter can remove any duplicate tokens that appear at the same position - sometimes
             possible with WordDelimiterGraphFilter in conjuncton with stemming. -->
      <filter name="removeDuplicates"/>
      <filter name="flattenGraph" />
    </analyzer>
    <analyzer type="query">
      <tokenizer name="whitespace"/>
      <filter name="synonymGraph" synonyms="synonyms.txt" ignoreCase="true" expand="false"/>
      <filter name="stop" ignoreCase="true" words="stopwords_en.txt"/>
      <filter name="wordDelimiterGraph" generateWordParts="0" generateNumberParts="0" catenateWords="1" catenateNumbers="1" catenateAll="0"/>
      <filter name="lowercase"/>
      <filter name="keywordMarker" protected="protwords.txt"/>
      <filter name="englishMinimalStem"/>
      <!-- this filter can remove any duplicate tokens that appear at the same position - sometimes
             possible with WordDelimiterGraphFilter in conjuncton with stemming. -->
      <filter name="removeDuplicates"/>
    </analyzer>
  </fieldType>

  <!-- The StrField type is not analyzed, but indexed/stored verbatim. -->
  <fieldType name="string" class="solr.StrField" sortMissingLast="true" />
  <fieldType name="strings" class="solr.StrField" sortMissingLast="true" multiValued="true" />

  <!-- boolean type: "true" or "false" -->
  <fieldType name="boolean" class="solr.BoolField" sortMissingLast="true"/>
  <fieldType name="booleans" class="solr.BoolField" sortMissingLast="true" multiValued="true"/>

  <!--
      Numeric field types that index values using KD-trees.
      Point fields don't support FieldCache, so they must have docValues enabled if needed for sorting, faceting, functions, etc.
      This is the default, so it does not need to be set explicitly.
    -->
  <fieldType name="pint" class="solr.IntPointField"/>
  <fieldType name="pfloat" class="solr.FloatPointField"/>
  <fieldType name="plong" class="solr.LongPointField"/>
  <fieldType name="pdouble" class="solr.DoublePointField"/>

  <fieldType name="pints" class="solr.IntPointField" multiValued="true"/>
  <fieldType name="pfloats" class="solr.FloatPointField" multiValued="true"/>
  <fieldType name="plongs" class="solr.LongPointField" multiValued="true"/>
  <fieldType name="pdoubles" class="solr.DoublePointField" multiValued="true"/>
  <fieldType name="random" class="solr.RandomSortField" indexed="true"/>

  <!-- since fields of this type are by default not stored or indexed,
       any data added to them will be ignored outright.  -->
  <fieldType name="ignored" stored="false" indexed="false" multiValued="true" docValues="false" class="solr.StrField" />

  <!-- KD-tree versions of date fields -->
  <fieldType name="pdate" class="solr.DatePointField"/>
  <fieldType name="pdates" class="solr.DatePointField" multiValued="true"/>

  <!--Binary data type. The data should be sent/retrieved in as Base64 encoded Strings -->
  <fieldType name="binary" class="solr.BinaryField"/>

  <!-- Date range field type-->
  <fieldType name="date_range" class="solr.DateRangeField"/>
  <fieldType name="date_ranges" class="solr.DateRangeField" multiValued="true"/>

  <!--
    RankFields can be used to store scoring factors to improve document ranking. They should be used
    in combination with RankQParserPlugin.
    (experimental)
    -->
  <fieldType name="rank" class="solr.RankField"/>

  <!-- A specialized field for geospatial search filters and distance sorting. -->
  <fieldType name="location" class="solr.LatLonPointSpatialField"/>

  <!-- An alternative geospatial field type new to Solr 4.  It supports multiValued and polygon shapes.
      For more information about this and other Spatial fields new to Solr 4, see:
      http://wiki.apache.org/solr/SolrAdaptersForLuceneSpatial4
    -->
  <fieldType name="location_rpt_jts" class="solr.SpatialRecursivePrefixTreeFieldType" geo="true" distErrPct="0.15" maxDistErr="0.05" distanceUnits="kilometers" autoIndex="true" validationRule="repairBuffer0" spatialContextFactory="JTS" datelineRule="ccwRect" normWrapLongitude="true"/>
  <fieldType name="geometry_rpt_geo3d" class="solr.SpatialRecursivePrefixTreeFieldType" geo="true" distErrPct="0.15" maxDistErr="0.05" spatialContextFactory="Geo3D" prefixTree="s2" planetModel="WGS84" normWrapLongitude="true"/>

  <!-- Spatial rectangle (bounding box) field. It supports most spatial predicates, and has
     special relevancy modes: score=overlapRatio|area|area2D (local-param to the query).  DocValues is recommended for
     relevancy. -->
  <fieldType name="bbox_pdouble" class="solr.DoublePointField" docValues="false"/>
  <fieldType name="bbox" class="solr.BBoxField" geo="true" distanceUnits="kilometers" numberType="bbox_pdouble" />

  <!-- For storing urls-->
  <fieldType name="url" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <!-- Tokenizer for breaking URL paths into hierarchy levels -->
      <tokenizer class="solr.PathHierarchyTokenizerFactory" delimiter="/" />
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.PatternReplaceFilterFactory" pattern="(https?|ftp)://" replacement="" replace="all"/>

    </analyzer>
    <analyzer type="query">
      <!-- Same tokenizer for query analysis -->
      <tokenizer class="solr.PathHierarchyTokenizerFactory" delimiter="/" />
      <filter class="solr.LowerCaseFilterFactory"/>
    </analyzer>
  </fieldType>



  <!-- A text field that only splits on whitespace for exact matching of words -->
  <dynamicField name="*_ws" type="text_ws" indexed="true" stored="true"/>
  <fieldType name="text_ws" class="solr.TextField" positionIncrementGap="100">
    <analyzer>
      <tokenizer name="whitespace"/>
    </analyzer>
  </fieldType>

  <fieldType name="boost_term_payload" stored="false" indexed="true" class="solr.TextField">
    <analyzer>
      <tokenizer class="solr.WhitespaceTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
      <filter class="solr.DelimitedPayloadTokenFilterFactory" encoder="float"/>
      <filter class="solr.LengthFilterFactory" min="2" max="100"/>
    </analyzer>
  </fieldType>


  <!-- lowercases the entire field value, keeping it as a single token.  -->
  <fieldType name="lowercase" class="solr.TextField" positionIncrementGap="100">
    <analyzer>
      <tokenizer class="solr.KeywordTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory" />
    </analyzer>
  </fieldType>

  <!-- FieldType for keywords stemming -->
  <!-- Splits GCMD-style keywords on '>' boundaries, e.g.
       "EARTH SCIENCE > OCEANS > OCEAN CHEMISTRY > BIOGEOCHEMICAL CYCLES"
       is tokenised into ["EARTH SCIENCE", "OCEANS", "OCEAN CHEMISTRY", "BIOGEOCHEMICAL CYCLES"].
       Underscores are replaced with spaces before tokenisation. -->
  <fieldType name="text_keyword_processed" class="solr.TextField" positionIncrementGap="100">
    <analyzer>
      <charFilter class="solr.PatternReplaceCharFilterFactory" pattern="_" replacement=" "/>
      <tokenizer class="solr.PatternTokenizerFactory" pattern="\s*&gt;\s*"/>
      <filter class="solr.TrimFilterFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.EnglishMinimalStemFilterFactory"/>
    </analyzer>
  </fieldType>


  <fieldType name="text_keywords" class="solr.TextField" positionIncrementGap="100" storeOffsetsWithPositions="true">
    <analyzer type="index">
      <tokenizer class="solr.WhitespaceTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" expand="false" ignoreCase="true"/>
      <filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
      <filter class="solr.EnglishMinimalStemFilterFactory"/>
      <filter class="solr.RemoveDuplicatesTokenFilterFactory"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.WhitespaceTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.SynonymGraphFilterFactory" synonyms="synonyms.txt" expand="true" ignoreCase="true"/>
      <filter class="solr.WordDelimiterGraphFilterFactory" generateWordParts="1" generateNumberParts="1" catenateWords="1" catenateNumbers="1" catenateAll="0" splitOnCaseChange="1" preserveOriginal="1"/>
      <filter class="solr.EnglishMinimalStemFilterFactory"/>
    </analyzer>
  </fieldType>

  <!-- Following is a dynamic way to include other types, added by other contrib modules -->
  &extratypes;
</schema>
